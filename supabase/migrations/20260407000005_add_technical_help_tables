-- =====================================================
-- MIGRATION: Création des tables pour l'aide technique
-- Date: 2026-04-08
-- =====================================================

BEGIN;

-- 1. Table des appels à solution technique
CREATE TABLE IF NOT EXISTS technical_help_requests (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  project_id UUID NOT NULL REFERENCES projects(id) ON DELETE CASCADE,
  title VARCHAR(255) NOT NULL,
  description TEXT NOT NULL,
  status VARCHAR(20) DEFAULT 'open',
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  updated_at TIMESTAMP WITH TIME ZONE DEFAULT NOW(),
  resolved_at TIMESTAMP WITH TIME ZONE,
  CONSTRAINT valid_status CHECK (status IN ('open', 'in_progress', 'resolved', 'closed'))
);

-- 2. Table des réponses aux appels à solution
CREATE TABLE IF NOT EXISTS technical_help_responses (
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  request_id UUID NOT NULL REFERENCES technical_help_requests(id) ON DELETE CASCADE,
  responder_email VARCHAR(255) NOT NULL,
  responder_name VARCHAR(255) NOT NULL,
  solution TEXT NOT NULL,
  is_accepted BOOLEAN DEFAULT FALSE,
  created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);

-- 3. Index pour optimiser les recherches
CREATE INDEX IF NOT EXISTS idx_technical_help_requests_project_id ON technical_help_requests(project_id);
CREATE INDEX IF NOT EXISTS idx_technical_help_requests_status ON technical_help_requests(status);
CREATE INDEX IF NOT EXISTS idx_technical_help_requests_created_at ON technical_help_requests(created_at DESC);
CREATE INDEX IF NOT EXISTS idx_technical_help_responses_request_id ON technical_help_responses(request_id);
CREATE INDEX IF NOT EXISTS idx_technical_help_responses_is_accepted ON technical_help_responses(is_accepted);

-- 4. Trigger pour updated_at
CREATE OR REPLACE FUNCTION update_technical_help_requests_updated_at()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_update_technical_help_requests_updated_at
BEFORE UPDATE ON technical_help_requests
FOR EACH ROW
EXECUTE FUNCTION update_technical_help_requests_updated_at();

-- 5. Row Level Security (RLS)
ALTER TABLE technical_help_requests ENABLE ROW LEVEL SECURITY;
ALTER TABLE technical_help_responses ENABLE ROW LEVEL SECURITY;

-- Politiques pour technical_help_requests
CREATE POLICY "Project owners can manage help requests"
ON technical_help_requests FOR ALL
USING (
  EXISTS (
    SELECT 1 FROM projects
    WHERE projects.id = technical_help_requests.project_id
    AND projects.user_id = auth.uid()
  )
);

CREATE POLICY "Anyone can view open help requests"
ON technical_help_requests FOR SELECT
USING (status = 'open');

CREATE POLICY "Anyone can view help requests for public projects"
ON technical_help_requests FOR SELECT
USING (
  EXISTS (
    SELECT 1 FROM projects
    WHERE projects.id = technical_help_requests.project_id
    AND projects.visibility = 'public'
  )
);

-- Politiques pour technical_help_responses
CREATE POLICY "Anyone can submit responses"
ON technical_help_responses FOR INSERT
WITH CHECK (true);

CREATE POLICY "Users can view responses for requests they can see"
ON technical_help_responses FOR SELECT
USING (
  EXISTS (
    SELECT 1 FROM technical_help_requests thr
    LEFT JOIN projects p ON p.id = thr.project_id
    WHERE thr.id = technical_help_responses.request_id
    AND (
      p.user_id = auth.uid()
      OR thr.status = 'open'
      OR p.visibility = 'public'
    )
  )
);

CREATE POLICY "Project owners can manage responses"
ON technical_help_responses FOR UPDATE
USING (
  EXISTS (
    SELECT 1 FROM technical_help_requests thr
    JOIN projects p ON p.id = thr.project_id
    WHERE thr.id = technical_help_responses.request_id
    AND p.user_id = auth.uid()
  )
);

-- 6. Commentaires
COMMENT ON TABLE technical_help_requests IS 'Appels à solution technique lancés par les propriétaires de projets';
COMMENT ON TABLE technical_help_responses IS 'Réponses des visiteurs aux appels à solution';
COMMENT ON COLUMN technical_help_requests.status IS 'open, in_progress, resolved, closed';
COMMENT ON COLUMN technical_help_responses.is_accepted IS 'Solution acceptée par le propriétaire du projet';

COMMIT;